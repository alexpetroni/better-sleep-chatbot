# generate a random secret: https://generate-secret.vercel.app/32 or `openssl rand -base64 32`
AUTH_SECRET=****

# required for non-vercel deployments, vercel uses OIDC automatically
# https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# https://vercel.com/docs/postgres
POSTGRES_URL=****

# https://vercel.com/docs/redis
REDIS_URL=****

# Sleep-coach intake pipeline — inference runs on Fireworks.ai
FIREWORKS_API_KEY=****
# When "true", logs a per-model token/cost breakdown to the server console.
SHOW_COST=
# Optional model overrides (Fireworks ids: accounts/fireworks/models/<name>).
# Defaults: deepseek-v3 (interview/extract/title), kimi-k2-instruct (assess).
INTERVIEW_MODEL=
EXTRACTOR_MODEL=
ASSESSOR_MODEL=
TITLE_MODEL=
# Optional cost rates in USD per 1M tokens, e.g.
# {"accounts/fireworks/models/deepseek-v3":{"input":0.9,"output":0.9}}
MODEL_PRICES_JSON=
